{
  "openapi": "3.0.1",
  "info": {
    "title": "Aduana Digital API",
    "description": "API para gestión de productos de importación",
    "version": "v1"
  },
  "paths": {
    "/api/ImportacionExcel/importar": {
      "post": {
        "tags": [
          "ImportacionExcel"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "archivo"
                ],
                "type": "object",
                "properties": {
                  "archivo": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/ProductoImportacion": {
      "post": {
        "tags": [
          "ProductoImportacion"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductoImportacion"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductoImportacion"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ProductoImportacion"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/WeatherForecast": {
      "get": {
        "tags": [
          "WeatherForecast"
        ],
        "operationId": "GetWeatherForecast",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProductoImportacion": {
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string",
            "nullable": true
          },
          "fotoUrl": {
            "type": "string",
            "nullable": true
          },
          "nombreChino": {
            "type": "string",
            "nullable": true
          },
          "pcsPorCaja": {
            "type": "integer",
            "format": "int32"
          },
          "cbmPorCaja": {
            "type": "number",
            "format": "double"
          },
          "explicacion": {
            "type": "string",
            "nullable": true
          },
          "tiendaContacto": {
            "type": "string",
            "nullable": true
          },
          "nombreEspanol": {
            "type": "string",
            "nullable": true
          },
          "autSant": {
            "type": "string",
            "nullable": true
          },
          "totalCajas": {
            "type": "integer",
            "format": "int32"
          },
          "totalCbm": {
            "type": "number",
            "format": "double"
          },
          "totalRmb": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "type": "integer",
            "format": "int32"
          },
          "temperatureF": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}